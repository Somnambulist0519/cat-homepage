---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { getWorks } from "@/utils/getWorks";

const works = await getWorks();
---

<Layout title={`作品 · ${config.site.title}`} description="作品与项目展示">
  <Header />
  <main id="main-content" class="app-wide">
    <section class="border-border border-b pt-12 pb-10">
      <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">作品</h1>
      <p class="mt-4 max-w-xl text-muted-foreground">
        一些我做过或正在做的东西。想添加作品，打开 <code>/admin</code> 后台（Sveltia CMS）即可在线编辑，无需改代码。
      </p>
    </section>

    <section class="py-12">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          works.map((w) => (
            <a
              href={w.link}
              target="_blank"
              rel="noopener"
              class="group block overflow-hidden rounded-card glass transition hover:-translate-y-0.5"
            >
              <img src={w.cover} alt={w.title} class="aspect-[16/10] w-full object-cover" />
              <div class="p-5">
                <h3 class="text-lg font-medium">{w.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{w.description}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {w.tags.map((tag) => (
                    <span class="rounded-full bg-muted px-2.5 py-0.5 text-xs text-muted-foreground">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
