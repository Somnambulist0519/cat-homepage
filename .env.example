# ===== 腾讯云 COS 部署（GitHub Actions Secrets / 本地脚本共用） =====
COS_SECRET_ID=你的SecretId
COS_SECRET_KEY=你的SecretKey
COS_BUCKET=your-bucket-1250000000      # 格式：桶名-APPID
COS_REGION=ap-guangzhou                # 存储桶地域
SITE_BASE_URL=your-domain.com          # 绑定的自定义域名（备案后填）

# ===== 联系/订阅表单后端（可选，预留接口） =====
# Formspree: https://formspree.io/f/xxxx
# 或腾讯云 SCF API 网关地址
CONTACT_ENDPOINT=
